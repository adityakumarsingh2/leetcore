        "id": "common-mistakes",
        "title": "10. Common Mistakes",
        "type": "mistakes",
        "items": [
          {
            "title": "Out of bounds access",
            "wrong": "int arr[3] = {1, 2, 3};\\ncout << arr[3];",
            "correct": "int arr[3] = {1, 2, 3};\\ncout << arr[2];",
            "why": "Array ka last valid index n - 1 hota hai. arr[3] invalid hai jab size 3 ho."
          },
          {
            "title": "Nested loop use karna jab optimized pattern possible ho",
            "wrong": "for (int i = 0; i < n; i++) {\\n    for (int j = i + 1; j < n; j++) {\\n        if (arr[i] + arr[j] == target) cout << i << \" \" << j;\\n    }\\n}",
            "correct": "unordered_map<int, int> mp;\\nfor (int i = 0; i < n; i++) {\\n    int need = target - arr[i];\\n    if (mp.count(need)) cout << mp[need] << \" \" << i;\\n    mp[arr[i]] = i;\\n}",
            "why": "Brute force O(n^2) hai, hashmap se same kaam O(n) me ho sakta hai."
          }
        ]
      },
